# ─────────────────────────────────────────────────────────────
# backend/.env.example
# Copy this file to backend/.env and fill in your values.
# NEVER commit backend/.env to version control.
# ─────────────────────────────────────────────────────────────

# MongoDB Atlas connection string
# Format: mongodb+srv://<user>:<password>@<cluster>.mongodb.net/<dbname>?retryWrites=true&w=majority
MONGO_URI=

# JWT secret — use a long, random string (256-bit / 32+ chars)
# Generate one: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
JWT_SECRET=

# Cloudinary credentials (from cloudinary.com → Settings → API Keys)
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# PORT — leave blank in production (Render injects it automatically).
# You may set PORT=5000 only for local development.
# PORT=5000
